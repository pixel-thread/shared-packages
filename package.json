{
  "name": "@pixel-thread/shared-packages",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Private source-code registry — install selected shared source files into your projects.",
  "bin": {
    "shared-packages": "dist/cli.js"
  },
  "files": [
    "dist",
    "registry.json",
    "src/items"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "pnpm build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "code-registry",
    "shared",
    "source"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.5",
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "axios": "^1.18.0",
    "eslint": "^10.5.0",
    "express": "^5.2.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "zod": "^4.4.3"
  }
}

{
  "name": "@pixel-thread/shared-packages",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Private source-code registry — install selected shared source files into your projects.",
  "bin": {
    "shared-packages": "dist/cli.js"
  },
  "files": [
    "dist",
    "registry.json",
    "src/items"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts",
    "dev": "tsup src/cli.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "code-registry",
    "shared",
    "source"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.5",
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "axios": "^1.18.0",
    "cors": "^2.8.6",
    "eslint": "^10.5.0",
    "eslint-config-expo": "^56.0.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "express": "^5.2.1",
    "globals": "^17.7.0",
    "helmet": "^8.2.0",
    "husky": "^9.1.7",
    "jose": "^6.2.3",
    "lint-staged": "^17.0.8",
    "multer": "^2.2.0",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "prettier": "^3.8.4",
    "ssh2-sftp-client": "^12.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
